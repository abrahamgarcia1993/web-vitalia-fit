{
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "data/**/*.json",
        "*.html",
        "articulos/**/*.html"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/articulos/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/:page*.html",
      "destination": "/api/index"
    },
    {
      "source": "/",
      "destination": "/api/index"
    }
  ]
}
